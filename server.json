{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.guanzhw/codefacts",
  "title": "CodeFacts",
  "description": "Local, verifiable code facts for coding agents.",
  "version": "0.1.2",
  "websiteUrl": "https://github.com/Guanzhw/codefacts#readme",
  "repository": {
    "url": "https://github.com/Guanzhw/codefacts",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "codefacts",
      "version": "0.1.2",
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
